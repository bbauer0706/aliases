{
  "general": {
    "editor": "code",
    "terminal_colors": true,
    "verbosity": "normal",
    "confirm_destructive_actions": true
  },
  "code": {
    "vscode_flags": [],
    "reuse_window": true,
    "fallback_behavior": "auto",
    "preferred_component": "server"
  },
  "env": {
    "base_port": 3000,
    "port_offset": 100,
    "default_env": "dev"
  },
  "sync": {
    "enabled": false,
    "remote_url": "",
    "auto_sync": false,
    "sync_interval": 86400,
    "last_sync": 0,
    "method": "git"
  },
  "projects": {
    "workspace_directories": ["~/workspaces"],
    "shortcuts": {},
    "server_paths": {},
    "web_paths": {},
    "ignore": [],
    "default_paths": {
      "server": ["java/serverJava", "serverJava", "backend", "server"],
      "web": ["webapp", "webApp", "web", "frontend", "client"]
    }
  },
  "prompt": {
    "enabled": true,
    "user_host_color": "bold_green",
    "default_path_color": "bold_blue",
    "path_replacements": [
      {
        "env_var": "INSTROOT",
        "label": "INSTROOT",
        "color": "bold_yellow"
      },
      {
        "path": "/opt/company/platform",
        "label": "PLATFORM",
        "color": "bold_yellow"
      }
    ]
  },
  "secrets": {
    "store_path": "",
    "kdf_iterations": 100000,
    "password_env_var": "ALIASES_MASTER_PASSWORD"
  }
}
